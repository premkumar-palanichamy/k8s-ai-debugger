# ── LLM ──────────────────────────────────────────────────────────────
# Anthropic (recommended — direct API, fastest)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenRouter (alternative — supports free tier, multiple models)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=anthropic/claude-3-haiku

# ── Kubernetes ────────────────────────────────────────────────────────
KUBECONFIG=~/.kube/config

# ── Database ──────────────────────────────────────────────────────────
DB_PATH=k8s_debugger.db

# ── Argo CD (optional) ────────────────────────────────────────────────
# Remove the # to enable ArgoCD integration.
# When enabled, investigations will also include ArgoCD app health,
# sync status, resource tree, and recent deployment history.
#
# ARGOCD_URL=https://your-argocd-server.example.com
#
# Option 1: API Token (recommended)
# ARGOCD_TOKEN=your_argocd_api_token
#
# Option 2: Username + Password
# ARGOCD_USERNAME=admin
# ARGOCD_PASSWORD=your_argocd_admin_password
